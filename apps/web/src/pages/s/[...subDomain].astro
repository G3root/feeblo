---
import { PublicBoardApp } from "@feeblo/public-feature-board";
import PublicBoardLayout from "../../layouts/PublicBoardLayout.astro";

export const prerender = false;

const { authHint, subdomain, site } = Astro.locals;

if (!subdomain) {
  throw new Error("Subdomain is required");
}

if (!site) {
  return new Response("Site not found", { status: 404 });
}
---

<PublicBoardLayout
  description={`Share feedback, follow the roadmap, and read product updates from ${site.name}.`}
  noIndex={site.noIndex}
  organizationId={site.organizationId}
  siteName={site.name}
  subdomain={site.subdomain}
  title={`${site.name} — Feedback and roadmap`}
>
  <main>
    <PublicBoardApp client:only="react" initialHint={authHint} site={site} />
  </main>
</PublicBoardLayout>

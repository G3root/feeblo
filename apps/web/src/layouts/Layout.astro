---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "feeblo" } = Astro.props;

import CommonHead from "./CommonHead.astro";
import EnvScript from "./EnvScript.astro";
import ThemeScript from "./ThemeScript.astro";
---

<!doctype html>
<html lang="en">
  <CommonHead title={title} />

  <style is:global>
    .pending-shell {
      --sidebar-width: calc(var(--spacing) * 72);
      --header-height: calc(var(--spacing) * 12);
      display: flex;
      width: 100%;
      height: 100dvh;
      min-height: 100svh;
      overflow: hidden;
      background-color: var(--sidebar);
    }
    .pending-shell__sidebar {
      position: relative;
      display: none;
      flex-direction: column;
      width: var(--sidebar-width);
      height: 100svh;
      padding: 0.5rem;
    }
    .pending-shell__sidebar-inner {
      display: flex;
      width: 100%;
      height: 100%;
    }
    .pending-shell__main {
      position: relative;
      display: flex;
      flex: 1;
      flex-direction: column;
      width: 100%;
      height: 100%;
      min-height: 0;
      overflow: hidden;
      background-color: var(--background);
    }
    .pending-shell__content {
      display: flex;
      flex: 1;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .pending-shell__loading {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      align-items: center;
    }
    @keyframes pending-shell-spin {
      0% {
        transform: rotate(0);
      }
      to {
        transform: rotate(360deg);
      }
    }
    .pending-shell__animate-spin {
      animation: 1s linear infinite pending-shell-spin;
    }
    .pending-shell__spinner {
      width: 1.5rem;
      height: 1.5rem;
    }
    .pending-shell__text {
      font-size: 0.875rem;
      line-height: 1.25rem;
      color: var(--muted-foreground);
    }
    @media (min-width: 768px) {
      .pending-shell__sidebar {
        display: flex;
      }
      .pending-shell__main {
        margin: 0.5rem;
        margin-inline-start: 0;
        border-radius: 1rem;
        box-shadow: 0 1px 2px #0000000d;
      }
    }
  </style>
  <EnvScript />
  <ThemeScript />

  <body>
    <slot />
  </body>
</html>

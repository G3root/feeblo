---
import "@feeblo/feedback-widget/styles";
import spriteSvgRaw from "@feeblo/feedback-widget/icons/sprite.svg?raw";
import CommonHead from "./CommonHead.astro";
import EnvScript from "./EnvScript.astro";

interface Props {
  organizationId: string;
  theme: string;
  title?: string;
}

const { title = "feeblo", organizationId, theme } = Astro.props;

const isDark = theme === "dark";
const spriteSvg = spriteSvgRaw.slice(spriteSvgRaw.indexOf("<svg"));
---

<!doctype html>
<html lang="en" data-theme={theme} class={isDark ? "dark" : ""}>
  <CommonHead title={title} />
  <EnvScript organizationId={organizationId} />
  <body>
    <div
      aria-hidden="true"
      style="position:absolute;width:0;height:0;overflow:hidden"
      set:html={spriteSvg}
    />
    <slot />
  </body>
</html>

---
interface Props {
  canonicalUrl?: string;
  clientHintCheckScript?: string;
  description?: string;
  noIndex?: boolean;
  ogImageUrl?: string;
  title?: string;
}

const {
  canonicalUrl,
  clientHintCheckScript,
  description,
  noIndex,
  ogImageUrl,
  title = "feeblo",
} = Astro.props;

import { Font } from "astro:assets";
import { SEO } from "astro-seo";
---

<head>
  <meta charset="UTF-8" />
  {
    clientHintCheckScript && (
      <script set:html={clientHintCheckScript} is:inline />
    )
  }
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <SEO
    title={title}
    description={description}
    canonical={canonicalUrl}
    noindex={noIndex}
    nofollow={false}
    openGraph={ogImageUrl
      ? {
          basic: {
            title,
            type: "website",
            image: ogImageUrl,
            url: canonicalUrl,
          },
          optional: {
            description,
          },
          image: {
            type: "image/png",
            width: 1200,
            height: 630,
            alt: `${title} social preview`,
          },
        }
      : undefined}
    twitter={{
      card: "summary_large_image",
      title,
      description,
      image: ogImageUrl,
      imageAlt: ogImageUrl ? `${title} social preview` : undefined,
    }}
  />
  <Font cssVariable="--font-inter" preload />
  <Font cssVariable="--font-geist-mono" preload />
</head>
